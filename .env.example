# ============================================================
# BakeryPilot — environment variables
# Copy to .env and fill in the values marked REQUIRED.
# Everything else has a working default for local dev.
# ============================================================


# ------------------------------------------------------------
# LLM — REQUIRED (at least one provider for chat)
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...          # get from console.anthropic.com
GOOGLE_API_KEY=                       # get from aistudio.google.com — enables Gemini models
GROQ_API_KEY=                         # get from console.groq.com — enables free Llama/Gemma models


# ------------------------------------------------------------
# Backend (FastAPI on :8000)
# ------------------------------------------------------------
DATABASE_URL=postgresql://bakery:bakery@localhost:5432/bakery
REDIS_URL=redis://localhost:6379
ALLOWED_ORIGINS=http://localhost:3000


# ------------------------------------------------------------
# Agent (LangGraph on :8001)
# ------------------------------------------------------------
BACKEND_URL=http://localhost:8000     # where the agent calls the backend API


# ------------------------------------------------------------
# MongoDB — prompt hot-reload store
# Falls back to local .md files if Mongo is unreachable.
# ------------------------------------------------------------
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=bakery_pilot
PROMPT_CACHE_TTL_SECONDS=60          # seconds before re-fetching a prompt from Mongo


# ------------------------------------------------------------
# Provider API keys (set any you want enabled; rest stay disabled in the picker)
# OPENAI_API_KEY:  get from platform.openai.com
# GOOGLE_API_KEY:  get from aistudio.google.com (Gemini)
# GROQ_API_KEY:    get from console.groq.com
# ------------------------------------------------------------
OPENAI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=


# ------------------------------------------------------------
# LLM model selection
# ------------------------------------------------------------
DEFAULT_MODEL=claude-sonnet-4-6      # catalog id — used when chat has no model selected
NEGOTIATION_MODEL=claude-sonnet-4-6  # fallback for negotiation when no chat model selected
SUMMARY_MODEL=claude-sonnet-4-6      # fallback for weekly summary when no chat model selected


# ------------------------------------------------------------
# Voice — Deepgram STT
# Leave blank to skip voice; text input still works.
# ------------------------------------------------------------
DEEPGRAM_API_KEY=                    # get from console.deepgram.com
DEEPGRAM_MODEL=nova-3                # nova-3 recommended; nova-2 is cheaper


# ------------------------------------------------------------
# LangSmith tracing (optional)
# Set LANGCHAIN_TRACING_V2=true to enable.
# ------------------------------------------------------------
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=bakery-pilot
LANGCHAIN_API_KEY=                   # get from smith.langchain.com


# ------------------------------------------------------------
# Opik evaluation (optional)
# Leave blank to run Opik in local mode (no account needed).
# ------------------------------------------------------------
OPIK_API_KEY=                        # get from comet.com/opik
OPIK_PROJECT=bakery-pilot


# ------------------------------------------------------------
# Frontend (Next.js on :3000)
# ------------------------------------------------------------
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000


# ------------------------------------------------------------
# Integration mock toggles
# Set to false only when wiring a real external system.
# ------------------------------------------------------------
SUPPLIER_USE_MOCK=true               # SAP S/4 HANA PO endpoint
MES_USE_MOCK=true                    # Manufacturing Execution System
CMMS_USE_MOCK=true                   # Maintenance work-order system
GMAIL_USE_MOCK=true                  # Gmail draft creation


# ------------------------------------------------------------
# Optional external feeds (fall back to seeded data if blank)
# ------------------------------------------------------------
CBOT_WHEAT_API_KEY=                  # commodity price feed
NEWS_API_KEY=                        # supplier risk news signal
